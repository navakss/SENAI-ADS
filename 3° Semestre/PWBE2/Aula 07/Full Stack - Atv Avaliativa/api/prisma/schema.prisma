generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Tarefa {
  id          Int      @id @default(autoincrement())
  img         String?
  nome        String
  descricao   String
  dataInicio  DateTime
  dataFim     DateTime
  status      Status   @default(PENDENTE)
}

enum Status {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
}